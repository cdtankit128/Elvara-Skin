{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "vendor": { "type": "text", "settings": { "text": "{{ product.vendor }}", "text_style": "uppercase" } },
        "title": { "type": "title" },
        "caption": { "type": "text", "settings": { "text": "{{ product.metafields.descriptors.subtitle.value }}", "text_style": "subtitle" } },
        "price": { "type": "price" },
        "benefit_highlights": { "type": "text", "settings": { "text": "🌿 100% Vegan & Cruelty-Free | ✨ Dermatologically Tested", "text_style": "caption-with-letter-spacing" } },
        "benefit_line": { "type": "benefit_line", "settings": { "text": "Deep hydration with a radiant glow in just days" } },
        "variant_picker": { "type": "variant_picker", "settings": { "picker_type": "button" } },
        "quantity_selector": { "type": "quantity_selector" },
        "urgency_indicator": { "type": "text", "settings": { "text": "Limited availability", "text_style": "subtitle" } },
        "buy_buttons": { "type": "buy_buttons", "settings": { "show_dynamic_checkout": true, "show_gift_card_recipient": true } },
        "trust_line": { "type": "trust_line", "settings": { "show_natural": true, "show_tested": true, "show_shipping": true } },
        "what_you_get": { "type": "what_you_get", "settings": { "title": "What You Get:", "content": "<ul><li>1x Elvara Night Cream<\/li><li>30-day usage<\/li><li>Suitable for all skin types<\/li><\/ul>" } },
        "trust_badges_pdp": { "type": "custom_liquid", "settings": { "custom_liquid": "{% render 'trust-badges-pdp' %}" } },
        "description": { "type": "description" },
        "collapsible-row-0": { "type": "collapsible_tab", "settings": { "heading": "Materials", "icon": "leather", "content": "", "page": "" } },
        "collapsible-row-1": { "type": "collapsible_tab", "settings": { "heading": "Shipping & Returns", "icon": "truck", "content": "", "page": "" } },
        "collapsible-row-2": { "type": "collapsible_tab", "settings": { "heading": "Dimensions", "icon": "ruler", "content": "", "page": "" } },
        "collapsible-row-3": { "type": "collapsible_tab", "settings": { "heading": "Care Instructions", "icon": "heart", "content": "", "page": "" } },
        "share": { "type": "share", "settings": { "share_label": "Share" } }
      },
      "block_order": [
        "vendor", "title", "caption", "price", "benefit_line", "variant_picker", "quantity_selector", "urgency_indicator", "buy_buttons", "trust_line", "what_you_get", "trust_badges_pdp", "description", "collapsible-row-0", "collapsible-row-1", "collapsible-row-2", "collapsible-row-3", "share"
      ],
      "settings": {
        "enable_sticky_info": true, "gallery_layout": "stacked", "media_size": "large", "constrain_to_viewport": true, "mobile_thumbnails": "hide", "hide_variants": true, "enable_video_looping": false, "padding_top": 36, "padding_bottom": 12
      }
    },
    "product_benefits": {
      "type": "product-benefits",
      "settings": {
        "heading": "Why You'll Love It",
        "background_color": "#FBFBF9",
        "padding_top": 80,
        "padding_bottom": 80
      }
    },
    "product_ingredients": {
      "type": "product-ingredients",
      "settings": {
        "heading": "What's Inside",
        "background_color": "#FFFFFF",
        "padding_top": 80,
        "padding_bottom": 80
      }
    },
    "product_reviews": {
      "type": "product-reviews-minimal",
      "settings": {
        "heading": "Loved by Thousands",
        "overall_rating": "4.8/5",
        "customer_count": "120+",
        "background_color": "#F5F1EB",
        "padding_top": 80,
        "padding_bottom": 80
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": { "heading": "Complete Your Routine", "heading_size": "h1", "columns_desktop": 4, "color_scheme": "scheme-1", "padding_top": 80, "padding_bottom": 80 }
    },
    "product_final_cta": {
      "type": "product-final-cta",
      "settings": {
        "heading": "Ready for Your Best Skin?",
        "subtext": "Join thousands of glowing customers and start your Elvara journey today.",
        "button_label": "Add to Cart",
        "background_color": "#FBFBF9",
        "padding_top": 100,
        "padding_bottom": 100
      }
    }
  },
  "order": ["main", "product_benefits", "product_ingredients", "product_reviews", "related-products", "product_final_cta"]
}
