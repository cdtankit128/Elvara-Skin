{% comment %}
  Renders trust badges on the Product Page (PDP)
{% endcomment %}

<div class="pdp-trust-badges" {{ block.shopify_attributes }}>
  <div class="pdp-trust-badge">
    <svg viewBox="0 0 24 24" fill="none" class="pdp-trust-icon" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"></path>
    </svg>
    <span class="pdp-trust-text">Free Shipping</span>
  </div>
  <div class="pdp-trust-badge">
    <svg viewBox="0 0 24 24" fill="none" class="pdp-trust-icon" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"></path>
    </svg>
    <span class="pdp-trust-text">30-Day Returns</span>
  </div>
  <div class="pdp-trust-badge">
    <svg viewBox="0 0 24 24" fill="none" class="pdp-trust-icon" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"></path>
    </svg>
    <span class="pdp-trust-text">Secure Checkout</span>
  </div>
  <div class="pdp-trust-badge">
    <svg viewBox="0 0 24 24" fill="none" class="pdp-trust-icon" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"></path>
    </svg>
    <span class="pdp-trust-text">Dermatologist Tested</span>
  </div>
</div>

<style>
  .pdp-trust-badges {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 2rem 0;
    margin-top: 2rem;
    border-top: 1px solid rgba(18, 18, 18, 0.08);
    gap: 1.5rem;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .pdp-trust-badges::-webkit-scrollbar {
    display: none;
  }
  .pdp-trust-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.8rem;
    flex: 1;
    min-width: 80px;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .pdp-trust-badge:hover {
    transform: translateY(-5px) scale(1.05);
  }
  .pdp-trust-icon {
    width: 28px;
    height: 28px;
    color: var(--color-accent);
    stroke-width: 1.25;
    background: rgba(var(--color-accent-rgb), 0.05);
    padding: 6px;
    border-radius: 50%;
  }
  .pdp-trust-text {
    font-size: 1rem;
    line-height: 1.3;
    color: var(--color-accent);
    font-weight: 500;
    letter-spacing: 0.01em;
  }
  @media screen and (max-width: 749px) {
    .pdp-trust-badges {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem 1rem;
    }
  }
</style>
