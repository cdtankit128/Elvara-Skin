{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .ingredient-story {
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
  }

  .ingredient-story__container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4rem;
  }

  @media screen and (min-width: 750px) {
    .ingredient-story__container {
      flex-direction: row;
      gap: 8rem;
    }
    
    .ingredient-story__container.layout--text_first {
      flex-direction: row-reverse;
    }
  }

  .ingredient-story__media {
    flex: 1;
    width: 100%;
    position: relative;
    border-radius: 2rem;
    overflow: hidden;
    aspect-ratio: 1 / 1.1;
  }

  .ingredient-story__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ingredient-story__content {
    flex: 1;
    width: 100%;
  }

  .ingredient-story__heading {
    margin-bottom: 2rem;
  }

  .ingredient-story__description {
    font-size: 1.6rem;
    line-height: 1.6;
    color: #4A4A4A;
    margin-bottom: 3rem;
  }

  .ingredient-story__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ingredient-story__item {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .ingredient-story__item-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: #4A4A4A;
    margin-top: 0.3rem;
  }

  .ingredient-story__item-icon svg {
    width: 100%;
    height: 100%;
  }

  .ingredient-story__item-text {
    font-size: 1.6rem;
    line-height: 1.4;
  }

  .ingredient-story__item-text strong {
    font-weight: 600;
    color: #000;
  }
{%- endstyle -%}

<div class="ingredient-story section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="ingredient-story__container layout--{{ section.settings.layout }}">
      <div class="ingredient-story__media">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: section.settings.image.alt }}
        {%- else -%}
          {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

      <div class="ingredient-story__content">
        {%- if section.settings.heading != blank -%}
          <h2 class="ingredient-story__heading h1">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <p class="ingredient-story__description">{{ section.settings.description }}</p>
        {%- endif -%}

        <ul class="ingredient-story__list">
          {%- for block in section.blocks -%}
            <li class="ingredient-story__item" {{ block.shopify_attributes }}>
              <div class="ingredient-story__item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div class="ingredient-story__item-text">
                <strong>{{ block.settings.ingredient_name }}</strong> – {{ block.settings.ingredient_benefit }}
              </div>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Ingredient Story",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Botanical Image"
    },
    {
      "type": "select",
      "id": "layout",
      "options": [
        { "value": "image_first", "label": "Image Left" },
        { "value": "text_first", "label": "Image Right" }
      ],
      "default": "image_first",
      "label": "Desktop Layout"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Powered by Nature",
      "label": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "description",
      "default": "Carefully selected botanical ingredients designed to nourish, restore, and protect your skin.",
      "label": "Description"
    },
    {
      "type": "color",
      "id": "bg_color",
      "default": "#FFFFFF",
      "label": "Background Color"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "ingredient_name",
          "default": "Ingredient Name",
          "label": "Name"
        },
        {
          "type": "inline_richtext",
          "id": "ingredient_benefit",
          "default": "Short benefit description.",
          "label": "Benefit"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ingredient Story",
      "blocks": [
        {
          "type": "ingredient",
          "settings": {
            "ingredient_name": "Vitamin C",
            "ingredient_benefit": "Brightens and evens skin tone"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "ingredient_name": "Hyaluronic Acid",
            "ingredient_benefit": "Deep hydration and plumping"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "ingredient_name": "Natural Oils",
            "ingredient_benefit": "Repair and restore skin barrier"
          }
        }
      ]
    }
  ]
}
{% endschema %}
