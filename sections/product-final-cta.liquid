{%- style -%}
  .product-final-cta {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .product-final-cta__container {
    max-width: 600px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 2;
  }

  .product-final-cta__heading {
    font-size: 3.6rem;
    letter-spacing: 0.1rem;
    margin-bottom: 1.5rem;
    color: #1A1A1A;
  }

  .product-final-cta__subtext {
    font-size: 1.6rem;
    color: #666;
    margin-bottom: 3.5rem;
    line-height: 1.5;
  }

  .product-final-cta__button {
    display: inline-block;
    padding: 1.8rem 4.5rem;
    background-color: #1A1A1A;
    color: #fff;
    text-decoration: none;
    font-size: 1.4rem;
    font-weight: 500;
    letter-spacing: 0.2rem;
    text-transform: uppercase;
    border-radius: 0.4rem;
    transition: all 0.3s ease;
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }

  .product-final-cta__button:hover {
    background-color: #333;
    transform: translateY(-2px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.15);
  }

  .product-final-cta__trust {
    margin-top: 3rem;
    font-size: 1.1rem;
    color: #999;
    letter-spacing: 0.05rem;
  }

  .product-final-cta__bg-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(123, 178, 132, 0.08) 0%, rgba(255,255,255,0) 70%);
    z-index: 1;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .product-final-cta__heading {
      font-size: 3rem;
    }
  }
{%- endstyle -%}

<section class="product-final-cta" id="FinalPush">
  <div class="product-final-cta__bg-glow"></div>
  <div class="product-final-cta__container">
    <h2 class="product-final-cta__heading">{{ section.settings.heading }}</h2>
    <p class="product-final-cta__subtext">{{ section.settings.subtext }}</p>
    
    <a href="{{ section.settings.button_link | default: product.url }}" class="product-final-cta__button">
      {{ section.settings.button_label }}
    </a>
    <span class="free-shipping-label" style="margin-top: 2rem;">Free shipping above ₹999</span>

    <div class="product-final-cta__trust">
      <span class="free-shipping-label">Free shipping above ₹999</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Final CTA (PDP)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Ready for Your Best Skin?",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subtext",
      "default": "Join thousands of glowing customers and start your Elvara journey today.",
      "label": "Subtext"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "Add to Cart",
      "label": "Button Label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link (Defaults to Product Page)"
    },
    {
      "type": "color",
      "id": "background_color",
      "default": "#FBFBF9",
      "label": "Background Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Final CTA (PDP)"
    }
  ]
}
{% endschema %}
