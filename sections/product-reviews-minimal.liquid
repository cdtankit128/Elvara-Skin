{%- style -%}
  .product-reviews {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
  }

  .product-reviews__container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .product-reviews__heading-group {
    text-align: center;
    margin-bottom: 5rem;
  }

  .product-reviews__rating-summary {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .review-stars {
    color: #7BB284;
    letter-spacing: 0.2rem;
    font-size: 1.8rem;
  }

  .review-rating-number {
    font-size: 1.6rem;
    font-weight: 500;
    color: #1A1A1A;
  }

  .product-reviews__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 3rem;
  }

  .review-card {
    background: #fff;
    padding: 3rem;
    border-radius: 1.2rem;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .review-card:hover {
    transform: translateY(-5px);
  }

  .review-card__stars {
    color: #7BB284;
    margin-bottom: 1.5rem;
    font-size: 1.2rem;
  }

  .review-card__text {
    font-size: 1.5rem;
    line-height: 1.6;
    color: #4A4A4A;
    font-style: italic;
    margin-bottom: 2rem;
    flex-grow: 1;
  }

  .review-card__author {
    font-size: 1.3rem;
    font-weight: 500;
    color: #1A1A1A;
    display: flex;
    align-items: center;
    gap: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1rem;
  }

  .review-card__author-verified {
    font-size: 1rem;
    color: #7BB284;
    text-transform: none;
    letter-spacing: 0;
    font-weight: 400;
  }

  @media screen and (max-width: 749px) {
    .product-reviews__grid {
      grid-template-columns: 1fr;
    }
  }
{%- endstyle -%}

<section class="product-reviews">
  <div class="product-reviews__container">
    <div class="product-reviews__heading-group">
      <h2 class="h1">{{ section.settings.heading }}</h2>
      <div class="product-reviews__rating-summary">
        <div class="review-stars">★★★★★</div>
        <div class="review-rating-number">{{ section.settings.overall_rating }} ({{ section.settings.customer_count }} reviews)</div>
      </div>
    </div>

    <div class="product-reviews__grid">
      {%- for block in section.blocks -%}
        <div class="review-card" {{ block.shopify_attributes }}>
          <div class="review-card__stars">★★★★★</div>
          <blockquote class="review-card__text">"{{ block.settings.text }}"</blockquote>
          <div class="review-card__author">
            {{ block.settings.author }}
            <span class="review-card__author-verified">Verified Buyer</span>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Minimal Reviews",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Loved by Thousands",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "overall_rating",
      "default": "4.8/5",
      "label": "Overall Rating Display"
    },
    {
      "type": "text",
      "id": "customer_count",
      "default": "120+",
      "label": "Review Count Display"
    },
    {
      "type": "color",
      "id": "background_color",
      "default": "#F5F1EB",
      "label": "Background Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "This changed my skin completely. Feels premium and actually works.",
          "label": "Review Text"
        },
        {
          "type": "text",
          "id": "author",
          "default": "Sarah M.",
          "label": "Author"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Minimal Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "text": "This changed my skin completely. Feels premium and actually works.",
            "author": "Sarah M."
          }
        },
        {
          "type": "review",
          "settings": {
            "text": "Best hydration product I've ever used. My skin feels plump all day.",
            "author": "Emma L."
          }
        },
        {
          "type": "review",
          "settings": {
            "text": "The natural glow is real. I get compliments on my skin every day now.",
            "author": "Jessica W."
          }
        }
      ]
    }
  ]
}
{% endschema %}
