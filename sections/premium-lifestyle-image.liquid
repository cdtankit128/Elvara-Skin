{%- style -%}
  .lifestyle-image {
    position: relative;
    width: 100%;
    margin: 0;
    overflow: hidden;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #000;
  }

  .lifestyle-image__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .lifestyle-image__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    opacity: 0.9;
  }

  .lifestyle-image__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.1) 50%, rgba(0,0,0,0.3) 100%);
    z-index: 2;
  }

  .lifestyle-image__content {
    position: relative;
    z-index: 3;
    text-align: center;
    color: #fff;
    max-width: 800px;
    padding: 0 2rem;
  }

  .lifestyle-image__heading {
    font-size: 6.4rem;
    font-weight: 300;
    letter-spacing: 0.4rem;
    margin-bottom: 2rem;
    text-transform: uppercase;
    text-shadow: 0 4px 15px rgba(0,0,0,0.1);
  }

  .lifestyle-image__subheading {
    font-size: 1.8rem;
    font-weight: 400;
    letter-spacing: 0.15rem;
    opacity: 0.9;
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .lifestyle-image {
      height: 80vh;
    }
    .lifestyle-image__heading {
      font-size: 3.6rem;
      letter-spacing: 0.2rem;
    }
    .lifestyle-image__subheading {
      font-size: 1.4rem;
    }
  }
{%- endstyle -%}

<section class="lifestyle-image section-{{ section.id }}-padding">
  <div class="lifestyle-image__bg">
    {%- if section.settings.image_url != blank -%}
      <img src="{{ section.settings.image_url }}" alt="{{ section.settings.heading }}" loading="lazy" width="1920" height="1080">
    {%- elsif section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 3840 | image_tag:
        loading: 'lazy',
        height: '100%',
        sizes: '100vw',
        widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
      }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>
  
  <div class="lifestyle-image__overlay"></div>

  <div class="lifestyle-image__content animate--fade-in">
    {%- if section.settings.heading != blank -%}
      <h2 class="lifestyle-image__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="lifestyle-image__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
    <div style="margin-top: 4rem;">
      <a href="/collections/all" class="button button--primary">Shop the Collection</a>
      <span class="free-shipping-label" style="color: #fff; opacity: 0.8;">Free shipping above ₹999</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Premium Lifestyle Image",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Lifestyle Image"
    },
    {
      "type": "text",
      "id": "image_url",
      "label": "Direct Image URL (Optional)"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Skincare, Elevated",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "default": "Crafted for those who value purity and performance",
      "label": "Subheading"
    }
  ],
  "presets": [
    {
      "name": "Premium Lifestyle Image"
    }
  ]
}
{% endschema %}
