{%- style -%}
  .results-proof {
    position: relative;
    width: 100%;
    margin: 0;
    overflow: hidden;
    height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .results-proof__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .results-proof__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    filter: contrast(0.9) saturate(0.9); /* Natural, Premium Feel */
  }

  .results-proof__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(223, 201, 171, 0.15); /* Soft Warm Tone */
    z-index: 2;
  }

  .results-proof__content {
    position: relative;
    z-index: 3;
    text-align: center;
    color: #fff;
    max-width: 800px;
    padding: 0 2rem;
  }

  .results-proof__heading {
    font-size: 5.2rem;
    font-weight: 300;
    letter-spacing: 0.2rem;
    margin-bottom: 2rem;
    text-transform: uppercase;
  }

  .results-proof__subheading {
    font-size: 1.8rem;
    font-weight: 400;
    letter-spacing: 0.1rem;
    margin-bottom: 3rem;
    opacity: 0.95;
    line-height: 1.4;
  }

  .results-proof__note {
    font-size: 1rem;
    opacity: 0.6;
    letter-spacing: 0.05rem;
    text-transform: uppercase;
    position: absolute;
    bottom: 3rem;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    z-index: 3;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .results-proof {
      height: 60vh;
    }
    .results-proof__heading {
      font-size: 3rem;
    }
    .results-proof__subheading {
      font-size: 1.4rem;
    }
  }
{%- endstyle -%}

<section class="results-proof section-{{ section.id }}-padding">
  <div class="results-proof__bg">
    {%- if section.settings.image_url != blank -%}
      <img src="{{ section.settings.image_url }}" alt="{{ section.settings.heading }}" loading="lazy" width="1920" height="1080">
    {%- elsif section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 3840 | image_tag:
        loading: 'lazy',
        height: '100%',
        sizes: '100vw',
        widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
      }}
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>
  
  <div class="results-proof__overlay"></div>

  <div class="results-proof__content animate--fade-in">
    {%- if section.settings.heading != blank -%}
      <h2 class="results-proof__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="results-proof__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
    <div style="margin-top: 4rem;">
      <a href="/collections/all" class="button button--primary">Get the Glow</a>
      <span class="free-shipping-label" style="color: #fff; opacity: 0.8;">Free shipping above ₹999</span>
    </div>
  </div>

  {%- if section.settings.show_note -%}
    <div class="results-proof__note">
      * Results may vary based on skin type and usage.
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Visible Results Section",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Results Image"
    },
    {
      "type": "text",
      "id": "image_url",
      "label": "Direct Image URL (Optional)"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Visible Glow. Real Results.",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "default": "Experience transformation you can see and feel",
      "label": "Subheading"
    },
    {
      "type": "checkbox",
      "id": "show_note",
      "default": true,
      "label": "Show 'Results may vary' note"
    }
  ],
  "presets": [
    {
      "name": "Visible Results Section"
    }
  ]
}
{% endschema %}
