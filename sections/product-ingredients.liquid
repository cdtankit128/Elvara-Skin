{%- style -%}
  .product-ingredients {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
    border-top: 1px solid rgba(0,0,0,0.03);
  }

  .product-ingredients__container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .product-ingredients__heading {
    text-align: center;
    font-size: 3.2rem;
    letter-spacing: 0.1rem;
    margin-bottom: 5rem;
    color: #1A1A1A;
  }

  .product-ingredients__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 4rem;
    text-align: center;
  }

  .ingredient-item__title {
    font-size: 1.8rem;
    font-weight: 500;
    margin: 0 0 1rem 0;
    color: #1A1A1A;
    letter-spacing: 0.05rem;
    text-transform: uppercase;
  }

  .ingredient-item__text {
    font-size: 1.4rem;
    line-height: 1.6;
    color: #666;
    margin: 0;
  }

  .ingredient-divider {
    width: 40px;
    height: 1px;
    background-color: #7BB284;
    margin: 2rem auto;
  }

  @media screen and (max-width: 749px) {
    .product-ingredients__grid {
      grid-template-columns: 1fr;
      gap: 5rem;
    }
  }
{%- endstyle -%}

<section class="product-ingredients">
  <div class="product-ingredients__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="product-ingredients__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="product-ingredients__grid">
      {%- for block in section.blocks -%}
        <div class="ingredient-item" {{ block.shopify_attributes }}>
          <h3 class="ingredient-item__title">{{ block.settings.title }}</h3>
          <div class="ingredient-divider"></div>
          <p class="ingredient-item__text">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Ingredients",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "What's Inside",
      "label": "Heading"
    },
    {
      "type": "color",
      "id": "background_color",
      "default": "#FBFBF9",
      "label": "Background Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "Vitamin C",
          "label": "Ingredient Name"
        },
        {
          "type": "text",
          "id": "text",
          "default": "Brightens skin and provides antioxidant protection.",
          "label": "Benefit Proof"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Ingredients",
      "blocks": [
        {
          "type": "ingredient",
          "settings": {
            "title": "Vitamin C",
            "text": "Brightens tone and protects against environmental stressors."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "title": "Hyaluronic Acid",
            "text": "Holds 1000x its weight in water for deep, multi-layer hydration."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "title": "Natural Oils",
            "text": "Rich in essential fatty acids to repair and seal the skin barrier."
          }
        }
      ]
    }
  ]
}
{% endschema %}
